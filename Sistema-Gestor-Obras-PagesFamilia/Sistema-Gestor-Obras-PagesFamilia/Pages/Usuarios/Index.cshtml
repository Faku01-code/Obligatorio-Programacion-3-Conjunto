@page
@model Sistema_Gestor_Obras_PagesFamilia.Pages.Usuarios.IndexModel
@{
    ViewData["Title"] = "Usuarios";
}

<div class="page-header">
    <div>
        <h2>Usuarios</h2>
        <p class="text-muted">Gestión de accesos y roles</p>
    </div>
    <a asp-page="Create" class="btn btn-light">
        <i class="bi bi-plus-lg"></i> Nuevo usuario
    </a>
</div>

<div class="glass-panel content-card">
    @if (Model.Usuarios.Any())
    {
        <table class="table-dark-custom">
            <thead>
                <tr>
                    <th>Email</th>
                    <th>Roles</th>
                    <th>Activo</th>
                    <th>Creado</th>
                    <th class="text-center">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var u in Model.Usuarios)
                {
                    <tr class="@(u.Activo == false ? "row-inactive" : "")">
                        <td><strong>@u.Email</strong></td>
                        <td>
                            @foreach (var rol in u.IdRols)
                            {
                                <span class="status-badge">@rol.Nombre</span>
                            }
                        </td>
                        <td>@(u.Activo == true ? "Sí" : "No")</td>
                        <td>@(u.FechaCreacion?.ToString("dd/MM/yyyy") ?? "-")</td>
                        <td class="text-center actions-cell">
                            <a asp-page="Edit" asp-route-id="@u.IdUsuario" class="btn-icon"><i class="bi bi-pencil"></i></a>
                            @if (u.Activo == true && u.IdUsuario != 1)
                            {
                                <a asp-page="Delete" asp-route-id="@u.IdUsuario" class="btn-icon btn-icon-danger"><i class="bi bi-trash"></i></a>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <div class="empty-state">
            <i class="bi bi-people"></i>
            <p>No hay usuarios</p>
        </div>
    }
</div>
