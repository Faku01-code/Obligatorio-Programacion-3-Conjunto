<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Pages & Familia</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    @{
        var estaLogueado = Context.Session.GetInt32("UsuarioId") != null;
        var nombreUsuario = Context.Session.GetString("UsuarioNombre") ?? "";
    }

    @if (estaLogueado)
    {
        <header class="topbar">
            <div class="topbar-brand">
                <a asp-page="/Index">
                    <span class="brand-bold">PAGES</span> & FAMILIA
                </a>
            </div>
            <nav class="topbar-nav">
                <a asp-page="/Index" class="topbar-btn">
                    <i class="bi bi-speedometer2"></i>
                    <span>Panel</span>
                </a>
                <a asp-page="/Obras/Index" class="topbar-btn">
                    <i class="bi bi-building"></i>
                    <span>Obras</span>
                </a>
                <a class="topbar-btn disabled">
                    <i class="bi bi-people"></i>
                    <span>Personal</span>
                </a>
                <a class="topbar-btn disabled">
                    <i class="bi bi-box-seam"></i>
                    <span>Materiales</span>
                </a>
                <a class="topbar-btn disabled">
                    <i class="bi bi-cash-stack"></i>
                    <span>Finanzas</span>
                </a>
                <a class="topbar-btn disabled">
                    <i class="bi bi-bar-chart"></i>
                    <span>Reportes</span>
                </a>
            </nav>
            <div class="topbar-user">
                <span class="user-name">@nombreUsuario</span>
                <a asp-page="/Account/Logout" class="topbar-btn-logout">
                    <i class="bi bi-box-arrow-right"></i>
                </a>
            </div>
        </header>
    }

    <main class="@(estaLogueado ? "main-content" : "")">
        @RenderBody()
    </main>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
