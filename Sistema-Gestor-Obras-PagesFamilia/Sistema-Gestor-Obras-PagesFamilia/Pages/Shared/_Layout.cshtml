<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Pages & Familia</title>
    <link rel="icon" type="image/png" href="~/favicon.png" asp-append-version="true" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <div class="page-loader" id="pageLoader">
        <div class="loader-spinner"></div>
    </div>

    @{
        var estaLogueado = Context.Session.GetInt32(Sistema_Gestor_Obras_PagesFamilia.Helpers.SessionKeys.UsuarioId) != null;
        var emailUsuario = Context.Session.GetString(Sistema_Gestor_Obras_PagesFamilia.Helpers.SessionKeys.UsuarioEmail) ?? "";
        var rolNombre = Context.Session.GetString(Sistema_Gestor_Obras_PagesFamilia.Helpers.SessionKeys.RolNombre) ?? "";
        var esAdmin = rolNombre == Sistema_Gestor_Obras_PagesFamilia.Helpers.Roles.Administrador;
    }

    @if (estaLogueado)
    {
        <div class="app-bg"></div>
        <header class="topbar glass-topbar">
            <div class="topbar-brand">
                <a asp-page="/Index">
                    <span class="brand-bold">PAGES</span> & FAMILIA
                </a>
            </div>
            <nav class="topbar-nav">
                <a asp-page="/Index" class="topbar-btn">
                    <i class="bi bi-speedometer2"></i>
                    <span>Panel</span>
                </a>
                <a asp-page="/Obras/Index" class="topbar-btn">
                    <i class="bi bi-building"></i>
                    <span>Obras</span>
                </a>
                <a asp-page="/Clientes/Index" class="topbar-btn">
                    <i class="bi bi-person-badge"></i>
                    <span>Clientes</span>
                </a>
                @if (esAdmin)
                {
                    <a asp-page="/Usuarios/Index" class="topbar-btn">
                        <i class="bi bi-shield-lock"></i>
                        <span>Usuarios</span>
                    </a>
                }
                <a asp-page="/Personal/Index" class="topbar-btn">
                    <i class="bi bi-people"></i>
                    <span>Personal</span>
                </a>
                <a asp-page="/Materiales/Index" class="topbar-btn">
                    <i class="bi bi-box-seam"></i>
                    <span>Materiales</span>
                </a>
                <a asp-page="/Finanzas/Index" class="topbar-btn">
                    <i class="bi bi-cash-stack"></i>
                    <span>Finanzas</span>
                </a>
            </nav>
            <div class="topbar-user">
                <span class="role-badge">@rolNombre</span>
                <span class="user-name">@emailUsuario</span>
                <a asp-page="/Account/Logout" class="topbar-btn-logout" title="Salir">
                    <i class="bi bi-box-arrow-right"></i>
                </a>
            </div>
        </header>
    }

    @if (TempData["Success"] != null)
    {
        <div class="toast-notification toast-success" id="appToast">
            <i class="bi bi-check-circle-fill toast-icon"></i>
            <span class="toast-message">@TempData["Success"]</span>
            <button class="toast-close" onclick="dismissToast()" aria-label="Cerrar">&times;</button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="toast-notification toast-error" id="appToast">
            <i class="bi bi-exclamation-circle-fill toast-icon"></i>
            <span class="toast-message">@TempData["Error"]</span>
            <button class="toast-close" onclick="dismissToast()" aria-label="Cerrar">&times;</button>
        </div>
    }

    <main class="@(estaLogueado ? "main-content" : "")">
        @RenderBody()
    </main>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
