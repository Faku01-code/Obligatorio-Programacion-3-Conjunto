@page
@model Sistema_Gestor_Obras_PagesFamilia.Pages.Clientes.IndexModel
@{
    ViewData["Title"] = "Clientes";
}

<div class="page-header">
    <div>
        <h2>Clientes</h2>
        <p class="text-muted">Comitentes de las obras</p>
    </div>
    @if (Model.EsAdministrador)
    {
        <a asp-page="Create" class="btn btn-light">
            <i class="bi bi-plus-lg"></i> Nuevo cliente
        </a>
    }
</div>

<div class="glass-panel content-card">
    @if (Model.Clientes.Any())
    {
        <table class="table-dark-custom">
            <thead>
                <tr>
                    <th>Nombre</th>
                    <th>Teléfono</th>
                    <th>Email</th>
                    <th>Activo</th>
                    @if (Model.EsAdministrador)
                    {
                        <th class="text-center">Acciones</th>
                    }
                </tr>
            </thead>
            <tbody>
                @foreach (var c in Model.Clientes)
                {
                    <tr class="@(c.Activo == false ? "row-inactive" : "")">
                        <td><strong>@c.Nombre</strong></td>
                        <td>@(c.Telefono ?? "-")</td>
                        <td>@(c.Email ?? "-")</td>
                        <td>@(c.Activo == true ? "Sí" : "No")</td>
                        @if (Model.EsAdministrador)
                        {
                            <td class="text-center actions-cell">
                                <a asp-page="Edit" asp-route-id="@c.IdCliente" class="btn-icon"><i class="bi bi-pencil"></i></a>
                                @if (c.Activo == true)
                                {
                                    <a asp-page="Delete" asp-route-id="@c.IdCliente" class="btn-icon btn-icon-danger"><i class="bi bi-trash"></i></a>
                                }
                            </td>
                        }
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <div class="empty-state">
            <i class="bi bi-person-badge"></i>
            <p>No hay clientes registrados</p>
            @if (Model.EsAdministrador)
            {
                <a asp-page="Create" class="btn btn-light">Crear primer cliente</a>
            }
        </div>
    }
</div>
