@page
@model Sistema_Gestor_Obras_PagesFamilia.Pages.IndexModel
@{
    ViewData["Title"] = "Dashboard";
}

<div class="page-header">
    <div>
        <h2>Panel de Control</h2>
        <p class="text-muted">Bienvenido, @Model.UsuarioEmail · @Model.RolNombre</p>
    </div>
    @if (Model.PuedeEscribir)
    {
        <a asp-page="/Obras/Create" class="btn btn-light">
            <i class="bi bi-plus-lg"></i> Nueva obra
        </a>
    }
</div>

<div class="stats-grid">
    <div class="glass-panel stat-card">
        <div class="stat-icon"><i class="bi bi-building"></i></div>
        <div class="stat-info">
            <div class="stat-number">@Model.Dashboard.TotalObrasActivas</div>
            <div class="stat-label">Obras Activas</div>
        </div>
    </div>
    <div class="glass-panel stat-card">
        <div class="stat-icon"><i class="bi bi-people"></i></div>
        <div class="stat-info">
            <div class="stat-number">@Model.Dashboard.TotalEmpleados</div>
            <div class="stat-label">Empleados</div>
        </div>
    </div>
    <div class="glass-panel stat-card">
        <div class="stat-icon"><i class="bi bi-person-badge"></i></div>
        <div class="stat-info">
            <div class="stat-number">@Model.Dashboard.TotalClientes</div>
            <div class="stat-label">Clientes</div>
        </div>
    </div>
    <div class="glass-panel stat-card">
        <div class="stat-icon fin-icon-ingreso"><i class="bi bi-graph-up-arrow"></i></div>
        <div class="stat-info">
            <div class="stat-number fin-num-ingreso">$@Model.TotalIngresos.ToString("N0")</div>
            <div class="stat-label">Ingresos</div>
        </div>
    </div>
    <div class="glass-panel stat-card">
        <div class="stat-icon fin-icon-egreso"><i class="bi bi-graph-down-arrow"></i></div>
        <div class="stat-info">
            <div class="stat-number fin-num-egreso">$@Model.TotalEgresos.ToString("N0")</div>
            <div class="stat-label">Egresos</div>
        </div>
    </div>
</div>

<div class="glass-panel content-card">
    <div class="section-header">
        <h3>Obras Recientes</h3>
        <a asp-page="/Obras/Index" class="btn btn-sm btn-outline-light">Ver todas</a>
    </div>

    @if (Model.Dashboard.ObrasRecientes.Any())
    {
        <table class="table-dark-custom">
            <thead>
                <tr>
                    <th>Nombre</th>
                    <th>Cliente</th>
                    <th>Estado</th>
                    <th>Inicio</th>
                    <th class="text-center">Acción</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var obra in Model.Dashboard.ObrasRecientes)
                {
                    <tr>
                        <td><strong>@obra.Nombre</strong></td>
                        <td>@obra.ClienteNombre</td>
                        <td><span class="status-badge">@obra.EstadoNombre</span></td>
                        <td>@(obra.FechaInicio?.ToString("dd/MM/yyyy") ?? "-")</td>
                        <td class="text-center">
                            <a asp-page="/Obras/Details" asp-route-id="@obra.IdObra" class="btn-icon">
                                <i class="bi bi-eye"></i>
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <div class="empty-state">
            <i class="bi bi-inbox"></i>
            <p>No hay obras registradas aún</p>
            @if (Model.PuedeEscribir)
            {
                <a asp-page="/Obras/Create" class="btn btn-light">Crear primera obra</a>
            }
        </div>
    }
</div>
