@page
@model IndexModel
@{
    // Página de bienvenida autocontenida: no usa _Layout para tener
    // control total del estilo. Cuando hagamos el área privada
    // (dashboard) ahí sí conviene un _Layout compartido.
    Layout = null;
    ViewData["Title"] = "Pages & Familia — Gestión de Obras";
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@Model.AppNombre — @Model.AppSubtitulo</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,400;12..96,600;12..96,800&family=Manrope:wght@400;500;600&display=swap" rel="stylesheet">

    <style>
            :root {
                --ink:     #1b1b1b;   /* grafito casi negro */
                --ink-2:   #3a3a3a;   /* grafito medio */
                --ink-3:   #6c6c6c;   /* texto atenuado */
                --line:    #dcdcd7;   /* hairlines */
                --line-2:  #ececea;   /* grilla de fondo */
                --paper:   #f5f5f2;   /* off-white base */
                --paper-2: #ffffff;
            }

            * { margin: 0; padding: 0; box-sizing: border-box; }

            html, body { height: 100%; }

            body {
                font-family: 'Manrope', system-ui, sans-serif;
                color: var(--ink);
                background-color: var(--paper);
                /* Grilla tipo plano técnico, muy sutil, como guiño a "obras" */
                background-image:
                    linear-gradient(var(--line-2) 1px, transparent 1px),
                    linear-gradient(90deg, var(--line-2) 1px, transparent 1px);
                background-size: 48px 48px;
                background-position: -1px -1px;
                -webkit-font-smoothing: antialiased;
                text-rendering: optimizeLegibility;
            }

            .shell {
                min-height: 100%;
                max-width: 1180px;
                margin: 0 auto;
                padding: 0 clamp(20px, 5vw, 56px);
                display: grid;
                grid-template-rows: auto 1fr auto;
            }

            /* ---------- Header ---------- */
            .topbar {
                display: flex;
                align-items: center;
                justify-content: space-between;
                padding: 26px 0;
                border-bottom: 1px solid var(--line);
            }

            .brand { display: flex; align-items: center; gap: 12px; }

            .brand .mark {
                width: 38px; height: 38px;
                display: grid; place-items: center;
                background: var(--ink);
                color: var(--paper);
                font-family: 'Bricolage Grotesque', sans-serif;
                font-weight: 800;
                font-size: 15px;
                letter-spacing: 0.5px;
            }

            .brand .name {
                font-family: 'Bricolage Grotesque', sans-serif;
                font-weight: 700;
                font-size: 18px;
                letter-spacing: -0.01em;
            }

            .nav { display: flex; align-items: center; gap: 30px; }

            .nav a {
                color: var(--ink-2);
                text-decoration: none;
                font-size: 14.5px;
                font-weight: 500;
                transition: color .18s ease;
            }
            .nav a:hover { color: var(--ink); }

            /* ---------- Hero ---------- */
            .hero {
                display: flex;
                flex-direction: column;
                justify-content: center;
                padding: clamp(48px, 9vw, 110px) 0;
                max-width: 760px;
            }

            .eyebrow {
                display: inline-flex;
                align-items: center;
                gap: 10px;
                font-size: 12px;
                letter-spacing: 0.18em;
                text-transform: uppercase;
                color: var(--ink-3);
                font-weight: 600;
                margin-bottom: 28px;
            }
            .eyebrow::before {
                content: "";
                width: 28px; height: 1px;
                background: var(--ink-3);
                display: inline-block;
            }

            .hero h1 {
                font-family: 'Bricolage Grotesque', sans-serif;
                font-weight: 800;
                font-size: clamp(2.4rem, 6vw, 4.4rem);
                line-height: 1.02;
                letter-spacing: -0.025em;
                margin-bottom: 24px;
            }
            .hero h1 .soft { color: var(--ink-3); }

            .hero p.lead {
                font-size: clamp(1rem, 1.6vw, 1.18rem);
                line-height: 1.6;
                color: var(--ink-2);
                max-width: 560px;
                margin-bottom: 40px;
            }

            .actions { display: flex; flex-wrap: wrap; gap: 14px; }

            .btn {
                display: inline-flex;
                align-items: center;
                gap: 9px;
                padding: 14px 26px;
                font-size: 15px;
                font-weight: 600;
                text-decoration: none;
                border: 1px solid var(--ink);
                transition: transform .15s ease, background .2s ease, color .2s ease;
            }
            .btn-primary { background: var(--ink); color: var(--paper); }
            .btn-primary:hover { transform: translateY(-2px); }
            .btn-ghost { background: transparent; color: var(--ink); }
            .btn-ghost:hover { background: var(--ink); color: var(--paper); }

            /* Tarjetitas de módulos del sistema */
            .modules {
                margin-top: clamp(40px, 7vw, 72px);
                display: grid;
                grid-template-columns: repeat(4, 1fr);
                border-top: 1px solid var(--line);
                border-left: 1px solid var(--line);
            }
            .module {
                padding: 22px 20px;
                border-right: 1px solid var(--line);
                border-bottom: 1px solid var(--line);
                background: var(--paper-2);
            }
            .module .k {
                font-family: 'Bricolage Grotesque', sans-serif;
                font-weight: 700;
                font-size: 14px;
                margin-bottom: 6px;
            }
            .module .d { font-size: 12.5px; color: var(--ink-3); line-height: 1.45; }

            /* ---------- Footer ---------- */
            .foot {
                display: flex;
                align-items: center;
                justify-content: space-between;
                flex-wrap: wrap;
                gap: 10px;
                padding: 24px 0;
                border-top: 1px solid var(--line);
                font-size: 12.5px;
                color: var(--ink-3);
            }
            .foot .team { letter-spacing: 0.01em; }

            /* ---------- Animación de entrada (sutil) ---------- */
            .reveal { opacity: 0; transform: translateY(14px); animation: up .7s ease forwards; }
            .d1 { animation-delay: .05s; }
            .d2 { animation-delay: .15s; }
            .d3 { animation-delay: .25s; }
            .d4 { animation-delay: .35s; }
            @@keyframes up { to { opacity: 1; transform: translateY(0); } }

            @@media (max-width: 760px) {
                .nav { gap: 18px; }
                .nav a.hide-sm { display: none; }
                .modules { grid-template-columns: repeat(2, 1fr); }
            }
            @@media (max-width: 420px) {
                .modules { grid-template-columns: 1fr; }
            }
    </style>
</head>
<body>
    <div class="shell">

        <header class="topbar">
            <div class="brand">
                <span class="mark">PF</span>
                <span class="name">Pages&nbsp;&amp;&nbsp;Familia</span>
            </div>
            <nav class="nav">
                <a href="#modulos" class="hide-sm">Módulos</a>
                <a href="#" class="hide-sm">Acerca de</a>
                <a href="/Login">Ingresar</a>
            </nav>
        </header>

        <main class="hero">
            <span class="eyebrow reveal d1">@Model.AppSubtitulo</span>

            <h1 class="reveal d2">
                Bienvenido a<br>
                Pages &amp; Familia.<br>
                <span class="soft">Cada obra, bajo control.</span>
            </h1>

            <p class="lead reveal d3">
                Plataforma interna para administrar obras, personal, materiales y
                movimientos financieros de la empresa. Centralizá la información de cada
                proyecto y seguí su avance de principio a fin.
            </p>

            <div class="actions reveal d4">
                <a href="/Login" class="btn btn-primary">Ingresar al sistema →</a>
                <a href="#modulos" class="btn btn-ghost">Ver módulos</a>
            </div>

            <section id="modulos" class="modules reveal d4">
                <div class="module">
                    <div class="k">Obras</div>
                    <div class="d">Estados, clientes y seguimiento de avance.</div>
                    <a href="./PruebaBdD" class="btn btn-primary">Gestionar<a/>
                </div>
                <div class="module">
                    <div class="k">Personal</div>
                    <div class="d">Empleados, oficios, asignaciones y horas.</div>
                </div>
                <div class="module">
                    <div class="k">Materiales</div>
                    <div class="d">Requerimientos y compras por obra.</div>
                </div>
                <div class="module">
                    <div class="k">Finanzas</div>
                    <div class="d">Ingresos, egresos y movimientos.</div>
                </div>
            </section>
        </main>

        <footer class="foot">
            <span>© @DateTime.Now.Year Pages &amp; Familia · Uso interno</span>
            <span class="team">Desarrollado por Alex Roth · Juan Meny · Facundo Villalba</span>
        </footer>

    </div>
</body>
</html>
