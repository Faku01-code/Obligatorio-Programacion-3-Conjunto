@page
@model Sistema_Gestor_Obras_PagesFamilia.Pages.Account.LoginModel
@{
    ViewData["Title"] = "Ingresar";
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Pages & Familia</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="login-body">
    <div class="login-bg"></div>

    <div class="login-split-container">

        <!-- ── COLUMNA IZQUIERDA: Formulario ── -->
        <div class="login-left glass-panel">

            <div class="login-brand">
                <span class="brand-bold">PAGES</span> & FAMILIA
            </div>
            <p class="login-subtitle">Sistema de Gestión de Obras</p>

            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="alert alert-danger">
                    <i class="bi bi-exclamation-circle"></i>
                    @Model.ErrorMessage
                </div>
            }

            <form method="post" class="login-form">
                <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

                <div class="form-group">
                    <label asp-for="Input.Email">Email</label>
                    <input asp-for="Input.Email" class="form-input glass-input" placeholder="admin@pages.com" autocomplete="username" />
                    <span asp-validation-for="Input.Email" class="validation-msg"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Input.Contrasenia">Contraseña</label>
                    <input asp-for="Input.Contrasenia" type="password" class="form-input glass-input" placeholder="••••••••" autocomplete="current-password" />
                    <span asp-validation-for="Input.Contrasenia" class="validation-msg"></span>
                </div>

                <div class="form-group">
                    <label>Ingresar como</label>
                    <div class="role-cards role-cards--horizontal">
                        @foreach (var rol in Model.RolesDisponibles)
                        {
                            var icon = rol.Nombre switch
                            {
                                "Administrador" => "bi-shield-lock",
                                "Capataz" => "bi-hammer",
                                "Consulta" => "bi-eye",
                                _ => "bi-person"
                            };
                            <label class="role-card glass-card-selectable">
                                <input type="radio" asp-for="Input.IdRol" value="@rol.IdRol" class="role-radio" />
                                <div class="role-card-inner role-card-inner--compact">
                                    <i class="bi @icon"></i>
                                    <span class="role-name">@rol.Nombre</span>
                                    <span class="role-desc">@rol.Descripcion</span>
                                </div>
                            </label>
                        }
                    </div>
                    <span asp-validation-for="Input.IdRol" class="validation-msg"></span>
                </div>

                <button type="submit" class="btn btn-light btn-login" id="loginBtn">
                    <i class="bi bi-box-arrow-in-right"></i> Ingresar
                </button>
            </form>
        </div>

        <!-- ── COLUMNA DERECHA: Bienvenida ── -->
        <div class="login-right">
            <div class="login-welcome">
                <div class="login-welcome-icon">
                    <i class="bi bi-building"></i>
                </div>
                <h1 class="login-welcome-title">
                    Bienvenido a<br />
                    <span class="brand-bold">Pages & Familia</span>
                </h1>
                <p class="login-welcome-desc">
                    Plataforma central de gestión de obras.<br />
                    Controlá el estado de tus proyectos, el personal,
                    los materiales y las finanzas desde un solo lugar.
                </p>
                <div class="login-welcome-features">
                    <div class="login-feature">
                        <i class="bi bi-clipboard-check"></i>
                        <span>Seguimiento de obras en tiempo real</span>
                    </div>
                    <div class="login-feature">
                        <i class="bi bi-people"></i>
                        <span>Gestión de personal y asignaciones</span>
                    </div>
                    <div class="login-feature">
                        <i class="bi bi-box-seam"></i>
                        <span>Control de materiales y compras</span>
                    </div>
                    <div class="login-feature">
                        <i class="bi bi-graph-up-arrow"></i>
                        <span>Reportes financieros por proyecto</span>
                    </div>
                </div>
            </div>
        </div>

    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/dist/jquery.validate.unobtrusive.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
</body>
</html>
