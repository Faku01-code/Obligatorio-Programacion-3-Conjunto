@page
@model Sistema_Gestor_Obras_PagesFamilia.Pages.Finanzas.CreateModel
@{
    ViewData["Title"] = "Nuevo Movimiento";
}

<div class="page-header">
    <div>
        <h2>Nuevo Movimiento Financiero</h2>
        <p class="text-muted">Registrar ingreso o egreso manual</p>
    </div>
    <a asp-page="/Finanzas/Index" class="btn btn-sm btn-outline-light">
        <i class="bi bi-arrow-left"></i> Volver
    </a>
</div>

<div class="glass-panel content-card" style="max-width:560px">
    <form method="post">
        <div asp-validation-summary="ModelOnly" class="glass-alert glass-alert-danger mb-3"></div>

        <div class="mb-3">
            <label class="field-label">Obra</label>
            <select asp-for="Input.IdObra" asp-items="Model.ObrasSelect" class="glass-select">
                <option value="0">— Seleccionar obra —</option>
            </select>
            <span asp-validation-for="Input.IdObra" class="field-validation-error"></span>
        </div>

        <div class="mb-3">
            <label class="field-label">Categoría</label>
            <select asp-for="Input.IdCategoria" class="glass-select" id="categoriaSelect">
                <option value="0">— Seleccionar categoría —</option>
                @foreach (var cat in Model.Categorias.OrderBy(c => c.Tipo).ThenBy(c => c.Nombre))
                {
                    <option value="@cat.IdCategoria"
                            data-tipo="@cat.Tipo"
                            selected="@(Model.Input.IdCategoria == cat.IdCategoria ? "selected" : null)">
                        @cat.Nombre (@cat.Tipo.ToLower())
                    </option>
                }
            </select>
            <span asp-validation-for="Input.IdCategoria" class="field-validation-error"></span>
        </div>

        <div class="mb-3">
            <label class="field-label">Monto</label>
            <input asp-for="Input.Monto" type="number" step="0.01" min="0.01" class="glass-input" placeholder="0.00" />
            <span asp-validation-for="Input.Monto" class="field-validation-error"></span>
        </div>

        <div class="mb-3">
            <label class="field-label">Fecha</label>
            <input asp-for="Input.Fecha" type="date" class="glass-input" />
            <span asp-validation-for="Input.Fecha" class="field-validation-error"></span>
        </div>

        <div class="mb-4">
            <label class="field-label">Descripción <span class="text-muted">(opcional)</span></label>
            <input asp-for="Input.Descripcion" class="glass-input" placeholder="Descripción del movimiento..." />
            <span asp-validation-for="Input.Descripcion" class="field-validation-error"></span>
        </div>

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-light">
                <i class="bi bi-check-lg"></i> Registrar
            </button>
            <a asp-page="/Finanzas/Index" class="btn btn-secondary">Cancelar</a>
        </div>
    </form>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}
