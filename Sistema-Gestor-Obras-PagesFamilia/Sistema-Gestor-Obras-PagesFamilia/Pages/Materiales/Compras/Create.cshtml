@page
@model Sistema_Gestor_Obras_PagesFamilia.Pages.Materiales.Compras.CreateModel
@{
    ViewData["Title"] = "Registrar compra";
}

<div class="page-header">
    <div>
        <h2>Registrar compra</h2>
        <p class="text-muted">
            @Model.ObraMaterial.IdMaterialNavigation?.Nombre —
            @Model.ObraMaterial.IdObraNavigation?.Nombre
        </p>
    </div>
</div>

<div class="glass-panel content-card form-card">
    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-danger">@Model.ErrorMessage</div>
    }

    <form method="post">
        <input type="hidden" asp-for="Input.IdObraMaterial" />
        <input type="hidden" name="returnObraId" value="@Model.ReturnObraId" />

        <div class="form-row-2">
            <div class="form-group">
                <label asp-for="Input.Cantidad" class="form-label">Cantidad *</label>
                <input asp-for="Input.Cantidad" type="number" step="0.01" min="0.01" class="form-control glass-input"
                       placeholder="Ej: 50" />
                <span asp-validation-for="Input.Cantidad" class="text-danger small"></span>
            </div>
            <div class="form-group">
                <label asp-for="Input.CostoUnitario" class="form-label">Costo unitario *</label>
                <input asp-for="Input.CostoUnitario" type="number" step="0.01" min="0" class="form-control glass-input"
                       placeholder="Ej: 1500.00" />
                <span asp-validation-for="Input.CostoUnitario" class="text-danger small"></span>
            </div>
        </div>

        <div class="form-row-2">
            <div class="form-group">
                <label asp-for="Input.Fecha" class="form-label">Fecha *</label>
                <input asp-for="Input.Fecha" type="date" class="form-control glass-input" />
                <span asp-validation-for="Input.Fecha" class="text-danger small"></span>
            </div>
            <div class="form-group">
                <label asp-for="Input.Descripcion" class="form-label">Descripción (opcional)</label>
                <input asp-for="Input.Descripcion" class="form-control glass-input"
                       placeholder="Ej: Proveedor X, factura 001" />
            </div>
        </div>

        <div class="form-actions">
            @if (Model.ReturnObraId.HasValue)
            {
                <a asp-page="/Obras/Details" asp-route-id="@Model.ReturnObraId" class="btn btn-secondary">Cancelar</a>
            }
            else
            {
                <a asp-page="/Obras/Index" class="btn btn-secondary">Cancelar</a>
            }
            <button type="submit" class="btn btn-light">Registrar</button>
        </div>
    </form>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}
