@page
@model Sistema_Gestor_Obras_PagesFamilia.Pages.Materiales.IndexModel
@{
    ViewData["Title"] = "Materiales";
}

<div class="page-header">
    <div>
        <h2>Materiales</h2>
        <p class="text-muted">Catálogo de insumos y materiales</p>
    </div>
    @if (Model.PuedeEscribir)
    {
        <div class="header-actions">
            <a asp-page="Create" class="btn btn-light btn-sm">
                <i class="bi bi-plus-lg"></i> Nuevo material
            </a>
        </div>
    }
</div>

<div class="glass-panel content-card">
    @if (Model.Materiales.Any())
    {
        <table class="table-dark-custom">
            <thead>
                <tr>
                    <th>Nombre</th>
                    <th>Unidad</th>
                    <th class="text-center">Estado</th>
                    <th class="text-center">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var m in Model.Materiales)
                {
                    <tr class="@(m.Activo == false ? "row-inactive" : "")">
                        <td>@m.Nombre</td>
                        <td>@m.Unidad</td>
                        <td class="text-center">
                            @if (m.Activo == true)
                            {
                                <span class="badge-active"><i class="bi bi-circle-fill"></i> Activo</span>
                            }
                            else
                            {
                                <span class="badge-inactive"><i class="bi bi-circle-fill"></i> Inactivo</span>
                            }
                        </td>
                        <td class="text-center actions-cell">
                            @if (Model.PuedeEscribir && m.Activo == true)
                            {
                                <a asp-page="Edit" asp-route-id="@m.IdMaterial" class="btn-icon" title="Editar">
                                    <i class="bi bi-pencil"></i>
                                </a>
                            }
                            @if (Model.PuedeEscribir && m.Activo == true)
                            {
                                <a asp-page="Delete" asp-route-id="@m.IdMaterial" class="btn-icon btn-icon-danger" title="Dar de baja">
                                    <i class="bi bi-archive"></i>
                                </a>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <div class="empty-state">
            <i class="bi bi-box-seam"></i>
            <p>No hay materiales registrados</p>
            @if (Model.PuedeEscribir)
            {
                <a asp-page="Create" class="btn btn-light btn-sm">Agregar el primero</a>
            }
        </div>
    }
</div>
