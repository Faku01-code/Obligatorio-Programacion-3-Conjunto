@page
@model Sistema_Gestor_Obras_PagesFamilia.Pages.Obras.PruebaBdDModel
@{
    Layout = null; // Mantenemos el aislamiento como en Index.cshtml
    ViewData["Title"] = "Prueba de Base de Datos";
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Pages & Familia</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,400;12..96,600;12..96,800&family=Manrope:wght@400;500;600&display=swap" rel="stylesheet">

    <style>
        :root {
            --ink:     #1b1b1b;
            --ink-2:   #3a3a3a;
            --ink-3:   #6c6c6c;
            --line:    #dcdcd7;
            --line-2:  #ececea;
            --paper:   #f5f5f2;
            --paper-2: #ffffff;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }
        html, body { height: 100%; }
        body {
            font-family: 'Manrope', system-ui, sans-serif;
            color: var(--ink);
            background-color: var(--paper);
            background-image:
                linear-gradient(var(--line-2) 1px, transparent 1px),
                linear-gradient(90deg, var(--line-2) 1px, transparent 1px);
            background-size: 48px 48px;
            background-position: -1px -1px;
            -webkit-font-smoothing: antialiased;
        }

        .shell {
            min-height: 100%;
            max-width: 1180px;
            margin: 0 auto;
            padding: 0 clamp(20px, 5vw, 56px);
            display: grid;
            grid-template-rows: auto 1fr auto;
        }

        /* Topbar compartida */
        .topbar {
            display: flex; align-items: center; justify-content: space-between;
            padding: 26px 0; border-bottom: 1px solid var(--line); margin-bottom: 40px;
        }
        .brand { display: flex; align-items: center; gap: 12px; }
        .brand .mark {
            width: 38px; height: 38px; display: grid; place-items: center;
            background: var(--ink); color: var(--paper);
            font-family: 'Bricolage Grotesque', sans-serif; font-weight: 800; font-size: 15px;
        }
        .brand .name { font-family: 'Bricolage Grotesque', sans-serif; font-weight: 700; font-size: 18px; }
        
        .nav { display: flex; align-items: center; gap: 30px; }
        .nav a { color: var(--ink-2); text-decoration: none; font-size: 14.5px; font-weight: 500; }
        .nav a:hover { color: var(--ink); }

        /* Títulos */
        h2 { font-family: 'Bricolage Grotesque', sans-serif; font-weight: 800; margin-bottom: 20px; font-size: 24px;}

        /* Contenedores de contenido */
        .content-grid { display: grid; grid-template-columns: 1fr 350px; gap: 40px; align-items: start; }
        @@media (max-width: 900px) { .content-grid { grid-template-columns: 1fr; } }

        /* Estilos de Tabla */
        .table-wrapper {
            background: var(--paper-2); border: 1px solid var(--line);
            overflow-x: auto; width: 100%;
        }
        table { width: 100%; border-collapse: collapse; }
        th, td { padding: 14px 18px; text-align: left; border-bottom: 1px solid var(--line); font-size: 14px; }
        th { font-family: 'Bricolage Grotesque', sans-serif; font-weight: 600; color: var(--ink-2); background: var(--paper); }
        tr:last-child td { border-bottom: none; }

        /* Formularios */
        .form-panel { background: var(--paper-2); border: 1px solid var(--line); padding: 24px; }
        .form-group.mb-3 { margin-bottom: 18px; }
        .form-group.mt-4 { margin-top: 24px; }
        .form-label { display: block; font-size: 13px; font-weight: 600; color: var(--ink-2); margin-bottom: 6px; }
        .form-control, .form-select {
            width: 100%; padding: 10px 14px; border: 1px solid var(--line);
            background: var(--paper); color: var(--ink); font-family: inherit; font-size: 14px;
            transition: border-color 0.2s ease;
        }
        .form-control:focus, .form-select:focus { outline: none; border-color: var(--ink); }
        
        /* Botones */
        .btn {
            display: inline-flex; align-items: center; justify-content: center; gap: 8px;
            padding: 10px 18px; font-size: 14px; font-weight: 600; text-decoration: none;
            border: 1px solid var(--ink); cursor: pointer; transition: all 0.2s ease; width: 100%;
        }
        .btn-primary { background: var(--ink); color: var(--paper); }
        .btn-primary:hover { background: var(--ink-2); }
        .btn-secondary { background: transparent; color: var(--ink); margin-top: 10px; }
        .btn-secondary:hover { background: var(--line-2); }
        .btn-sm { padding: 6px 12px; font-size: 13px; width: auto; }
        .btn-danger { background: transparent; color: #d32f2f; border-color: #d32f2f; }
        .btn-danger:hover { background: #d32f2f; color: var(--paper-2); }
    </style>
</head>
<body>
    <div class="shell">
        <header class="topbar">
            <div class="brand">
                <span class="mark">PF</span>
                <span class="name">Pages&nbsp;&amp;&nbsp;Familia</span>
            </div>
            <nav class="nav">
                <a href="/">Volver al Inicio</a>
            </nav>
        </header>

        <main>
            <div class="content-grid">
                <div>
                    <h2>Obras Registradas</h2>
                    <div class="table-wrapper">
                        <table>
                            <thead>
                                <tr>
                                    <th>Nombre</th>
                                    <th>Dirección</th>
                                    <th>Cliente</th>
                                    <th>Estado</th>
                                    <th>Acciones</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model.Obras != null && Model.Obras.Any())
                                {
                                    foreach (var item in Model.Obras)
                                    {
                                        <tr>
                                            <td>@item.Nombre</td>
                                            <td>@item.Direccion</td>
                                            <td>@(item.IdClienteNavigation?.Nombre ?? "Sin Cliente")</td>
                                            <td>@(item.IdEstadoNavigation?.Nombre ?? "Sin Estado")</td>
                                            <td>
                                                <form method="post" asp-page-handler="Delete" asp-route-id="@item.IdObra" onsubmit="return confirm('¿Seguro que deseas eliminar esta obra?');">
                                                    <button type="submit" class="btn btn-danger btn-sm">Eliminar</button>
                                                </form>
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="5" style="text-align: center; color: var(--ink-3);">No hay obras registradas.</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>

                <div>
                    <h2>Nueva Obra</h2>
                    <div class="form-panel">
                        <form method="post">
                            <div asp-validation-summary="All" style="color: #d32f2f; font-size: 13px; margin-bottom: 12px;"></div>

                            <div class="form-group mb-3">
                                <label asp-for="Obra.Nombre" class="form-label">Nombre de la Obra</label>
                                <input asp-for="Obra.Nombre" class="form-control" required />
                            </div>
                            <div class="form-group mb-3">
                                <label asp-for="Obra.Direccion" class="form-label">Dirección</label>
                                <input asp-for="Obra.Direccion" class="form-control" />
                            </div>
                            <div class="form-group mb-3">
                                <label asp-for="Obra.Descripcion" class="form-label">Descripción</label>
                                <textarea asp-for="Obra.Descripcion" class="form-control" rows="3"></textarea>
                            </div>
                            
                            <div class="form-group mb-3">
                                <label asp-for="Obra.IdCliente" class="form-label">Cliente</label>
                                <select asp-for="Obra.IdCliente" class="form-select" asp-items="Model.Clientes" required>
                                    <option value="">-- Seleccionar Cliente --</option>
                                </select>
                            </div>

                            <div class="form-group mb-3">
                                <label asp-for="Obra.IdEstado" class="form-label">Estado de Obra</label>
                                <select asp-for="Obra.IdEstado" class="form-select" asp-items="Model.Estados" required>
                                    <option value="">-- Seleccionar Estado --</option>
                                </select>
                            </div>

                            <div class="form-group mb-3">
                                <label asp-for="Obra.FechaInicio" class="form-label">Fecha de Inicio</label>
                                <input asp-for="Obra.FechaInicio" class="form-control" type="date" />
                            </div>

                            <div class="form-group mb-3">
                                <label asp-for="Obra.FechaFinEstimada" class="form-label">Fecha de finalizacion</label>
                                <input asp-for="Obra.FechaFinEstimada" class="form-control" type="date" />
                            </div>

                            <div class="form-group mt-4">
                                <button type="submit" class="btn btn-primary">Guardar Registro</button>
                                <a href="/" class="btn btn-secondary" style="text-align: center;">Cancelar</a>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </main>
        
        <footer style="margin-top: 40px; border-top: 1px solid var(--line); padding: 24px 0; font-size: 12.5px; color: var(--ink-3);">
            © @DateTime.Now.Year Pages & Familia · Panel de Pruebas BdD
        </footer>
    </div>
</body>
</html>
